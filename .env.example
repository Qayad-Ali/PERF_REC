# Copy to .env and fill in. .env is gitignored.

# Kaggle API (get from kaggle.com > Account > Create New API Token -> kaggle.json)
KAGGLE_USERNAME=
KAGGLE_KEY=


# LLM (choose your provider)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Qdrant (local docker default; or Qdrant Cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Optional: weather API for live climate resolution (Phase 2)
WEATHER_API_KEY=
